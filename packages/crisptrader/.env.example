# Environment Variables for CrispTrader
# Copy this file to .env.local and fill in the values

# ===========================================
# CLERK — Authentication
# https://clerk.com
# ===========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ===========================================
# DATABASE — Neon Postgres
# https://neon.tech
# ===========================================
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/crisptrader?sslmode=require

# ===========================================
# STRIPE — Payments
# https://stripe.com
# ===========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price IDs (create in Stripe dashboard)
STRIPE_PRICE_STACKER=price_...
STRIPE_PRICE_VAULT=price_...

# ===========================================
# RESEND — Email
# https://resend.com
# ===========================================
RESEND_API_KEY=re_...
EMAIL_FROM=alerts@crisptrader.com
EMAIL_FROM_NAME=CrispTrader

# ===========================================
# POLLER — Internal API Security
# ===========================================
# Shared secret between lin TX poller and Vercel API
# Generate with: openssl rand -hex 32
INTERNAL_POLLER_SECRET=

# ===========================================
# METALS.DEV — Spot Price Data
# https://metals.dev
# ===========================================
METALS_DEV_API_KEY=

# ===========================================
# SENTRY — Error Tracking (optional for dev)
# https://sentry.io
# ===========================================
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_DSN=
