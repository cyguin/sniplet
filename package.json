{
  "name": "@cyguin/sniplet",
  "version": "0.1.6",
  "type": "module",
  "description": "Drop-in snippet sharing for Next.js apps",
  "keywords": ["code-snippets", "pastebin", "nextjs", "snippet-sharing", "developer-tools", "syntax-highlighting"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joeproit/sniplet"
  },
  "bin": {
    "sniplet": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./next": "./dist/next/index.js",
    "./react": "./dist/react/index.js",
    "./adapters/sqlite": "./dist/adapters/sqlite.js",
    "./adapters/postgres": "./dist/adapters/postgres.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "nanoid": "^5.1.7",
    "postgres": "^3.4.8",
    "shiki": "^1.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "next": "^14.2.35",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
