{
  "name": "@cyguin/sniplet",
  "version": "0.2.6",
  "description": "Pastebin for code. Drop-in snippet sharing for Next.js with syntax highlighting, burn-on-read, and expiry.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyguin/sniplet"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./adapters/sqlite": {
      "import": "./dist/adapters/sqlite.js",
      "types": "./dist/adapters/sqlite.d.ts"
    },
    "./adapters/postgres": {
      "import": "./dist/adapters/postgres.js",
      "types": "./dist/adapters/postgres.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "dependencies": {
    "nanoid": "^5.0.0",
    "shiki": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "typescript": "^5.3.0",
    "tsup": "^8.0.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "keywords": [
    "pastebin",
    "snippet",
    "code",
    "nextjs",
    "syntax-highlighting"
  ],
  "license": "MIT",
  "author": {
    "name": "cyguin LLC",
    "url": "https://cyguin.com"
  }
}
